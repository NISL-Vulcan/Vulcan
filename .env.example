# vulcan 训练系统环境配置
# 复制此文件为 .env 并根据需要修改参数

# 默认训练参数
DEFAULT_TRAINING_EPOCHS=10
DEFAULT_BATCH_SIZE=128
DEFAULT_LEARNING_RATE=0.001
DEFAULT_EVAL_INTERVAL=1
DEFAULT_DEVICE=cuda
DEFAULT_SAVE_DIR=output

# 快速模式参数（用于测试和快速验证）
QUICK_MODE_EPOCHS=2
QUICK_MODE_BATCH_SIZE=32
QUICK_MODE_LEARNING_RATE=0.0002

# 生产模式参数（用于正式训练）
PRODUCTION_MODE_EPOCHS=100
PRODUCTION_MODE_BATCH_SIZE=64
PRODUCTION_MODE_LEARNING_RATE=0.0001

# 系统配置
LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_HOURS=24

# 数据路径配置
DEFAULT_DATASET_ROOT=./dataset
DEFAULT_MODEL_SAVE_PATH=./checkpoints

# GPU配置
CUDA_VISIBLE_DEVICES=0
MIXED_PRECISION=true
GRADIENT_ACCUMULATION_STEPS=1 